# GEMINI_API_KEY and JWT_SECRET are now Worker *secrets*, not plain env vars.
# Set them with:
#   wrangler secret put GEMINI_API_KEY
#   wrangler secret put JWT_SECRET
# For local dev, put them in .dev.vars (gitignored) instead:
#   GEMINI_API_KEY="your_key"
#   JWT_SECRET="a_long_random_string"

# VITE_TRANSLATE_API_URL: Optional client-side URL override for translation API.
# If omitted, defaults to using the relative "/api/translate" route.
VITE_TRANSLATE_API_URL=
